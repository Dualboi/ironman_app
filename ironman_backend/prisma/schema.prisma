generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  email     String   @unique
  name      String
  createdAt DateTime @default(now())

  plans    TrainingPlan[]
  profile  UserProfile?
  sessions Session[]
}

model UserProfile {
  id         String @id @default(uuid())
  userId     String @unique
  bodyWeight Float
  age        Int
  gender     Gender

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrainingPlan {
  id        String   @id @default(uuid())
  userId    String
  name      String
  goalType  GoalType
  startDate DateTime
  endDate   DateTime

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals TrainingGoal[]
  weeks Week[]
}

model Week {
  id             String   @id @default(uuid())
  trainingPlanId String
  weekNumber     Int
  startDate      DateTime

  trainingPlan TrainingPlan    @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  sessions     Session[]
  logs         SuggestionLog[]
}

model WorkoutType {
  id   String @id @default(uuid())
  name String @unique

  sessions Session[]
}

model Session {
  id              String    @id @default(uuid())
  userId          String
  weekId          String?
  workoutTypeId   String
  dayOfWeek       Int?
  intensity       Intensity
  durationMinutes Int
  distanceKm      Float?
  isCompleted     Boolean   @default(false)

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  week        Week?           @relation(fields: [weekId], references: [id], onDelete: Cascade)
  workoutType WorkoutType     @relation(fields: [workoutTypeId], references: [id])
  logs        SuggestionLog[]
}

model TrainingGoal {
  id             String @id @default(uuid())
  trainingPlanId String
  goalType       String
  targetValue    Float
  unit           String

  trainingPlan TrainingPlan @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
}

model SuggestionLog {
  id            String     @id @default(uuid())
  weekId        String
  sessionId     String
  actionType    ActionType
  description   String
  previousValue Json?
  newValue      Json?
  createdAt     DateTime   @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  week    Week    @relation(fields: [weekId], references: [id], onDelete: Cascade)
}

enum Gender {
  male
  female
  other
}

enum Intensity {
  Recovery
  Zone2
  Tempo
  Threshold
  sprint
  TestOrRace
}

enum GoalType {
  totalTime
  totalDistance
}

enum ActionType {
  MOVE
  ADD
  UPDATE
  REMOVE
}
