{
  "compilerOptions": {
    "target": "ES2020",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "ignoreDeprecations": "6.0",

    "rootDir": "./src",
    "outDir": "./dist",

    "baseUrl": "./src",
    "paths": {
    "@/*": ["*"]
    },

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  }
}